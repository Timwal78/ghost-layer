# Ghost Layer — environment variable reference
# Copy to .env and fill in values; never commit .env to version control.

# ── Gateway configuration ─────────────────────────────────────────────────────

# Port the ghost gateway listens on (default: 7391)
PORT=7391

# Base URL of the upstream API this gateway brokers to.
# Must be an https:// or http:// URL pointing to a public host.
# Private/internal addresses (127.x, 10.x, 192.168.x, 169.254.x, etc.)
# are rejected by the SSRF protection layer.
UPSTREAM_URL=https://api.example.com

# Optional: real API key injected as Authorization: Bearer <key> when
# forwarding to the upstream.  Read from the environment — never pass on
# the CLI command line (would appear in `ps aux`).
GHOST_UPSTREAM_KEY=

# ── VAPL (Verifiable Agent Provenance Layer) ──────────────────────────────────

# Path where the VAPL soul key-pair is persisted across restarts.
# Defaults to /tmp/vapl_soul_ghost.json — override in production so the
# DID stays stable across container restarts (e.g. mount a persistent volume).
VAPL_SOUL_FILE=/data/vapl_soul_ghost.json

# ── Ghost home directory ──────────────────────────────────────────────────────

# Directory where session keys and the residue SQLite database are stored.
# Defaults to ~/.ghost
GHOST_HOME=/data/ghost
